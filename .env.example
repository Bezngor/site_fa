# Публичный URL сайта (metadataBase, абсолютные URL в OG/Twitter).
# prod: https://factoryall.ru; на превью/Vercel — свой URL (например https://xxx.vercel.app).
NEXT_PUBLIC_SITE_URL=https://factoryall.ru

# Formspree: ID формы (без URL); в коде: https://formspree.io/f/{NEXT_PUBLIC_FORMSPREE_ID}
NEXT_PUBLIC_FORMSPREE_ID=your-form-id

# Необязательно: email для mailto-fallback (по умолчанию hello@factoryall.ru)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@factoryall.ru
